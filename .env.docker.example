# 复制为 .env.docker 后按需修改：cp .env.docker.example .env.docker

# 宿主机映射端口（容器内固定为 80）
HOST_PORT=3080

# 页面默认 API 地址
DEFAULT_API_URL=https://mzlone.top/v1

# API 代理上游地址（开启代理时生效）
API_PROXY_URL=https://mzlone.top/v1

# 是否开启同源 /api-proxy/ 代理
ENABLE_API_PROXY=true

# 是否锁定代理开关（用户无法关闭）
LOCK_API_PROXY=true

# 是否仅允许使用默认配置（可选）
SHOW_DEFAULT_CONFIG_ONLY=false
